{
  "name": "Spark 4.0 PySpark",

  // 直接使用官方镜像
  "image": "apache/spark:4.0.2-python3",

  // 容器启动时保持运行，而不是执行镜像默认命令（jshell 等）
  "overrideCommand": true,

  // 工作目录（镜像里 WORKDIR 是 /opt/spark/work-dir，我们就用这个）
  "workspaceFolder": "/opt/spark/work-dir",

  // 容器环境变量
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  },

  // VS Code 相关
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "python"
      }
    }
  },
  
  "hostRequirements":{
    "memory":"8GB"
  }
}
